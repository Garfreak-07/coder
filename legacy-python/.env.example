# Choose one provider.
# Supported without extra dependencies:
# openai, openai-compatible, deepseek, moonshot, kimi, qwen, dashscope, ollama
CODER_PROVIDER=openai
CODER_MODEL=gpt-4.1-mini

# OpenAI
OPENAI_API_KEY=

# Generic OpenAI-compatible endpoint
# CODER_PROVIDER=openai-compatible
# CODER_MODEL=your-model-name
# CODER_BASE_URL=https://your-provider.example.com/v1
# CODER_API_KEY=

# DeepSeek
# CODER_PROVIDER=deepseek
# CODER_MODEL=deepseek-chat
# DEEPSEEK_API_KEY=

# Optional OpenHands runtime provider. Requires Python 3.12+ with
# openhands-sdk and openhands-tools installed locally.
# CODER_ENABLE_OPENHANDS_RUNTIME=1
# LLM_API_KEY=
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-v4-flash

# Moonshot / Kimi
# CODER_PROVIDER=kimi
# CODER_MODEL=moonshot-v1-8k
# MOONSHOT_API_KEY=

# Qwen / DashScope OpenAI-compatible mode
# CODER_PROVIDER=qwen
# CODER_MODEL=qwen-plus
# DASHSCOPE_API_KEY=

# Ollama local model
# CODER_PROVIDER=ollama
# CODER_MODEL=qwen2.5-coder:7b
# OLLAMA_BASE_URL=http://localhost:11434/v1
