{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Coder",
  "version": "0.1.0",
  "identifier": "com.coder.workbench",
  "build": {
    "beforeDevCommand": "npm --prefix frontend run dev -- --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm --prefix frontend run build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Coder",
        "width": 1280,
        "height": 860,
        "minWidth": 980,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
